  "scripts": {
    "start": "concurrently \"npm run server\" \"node scripts/start.js\" ",
    "server": "nodemon",
    "build": "node --max_old_space_size=1024 -r ts-node/register scripts/build.js",
    "test": "node scripts/test.js",
    "codegen": "graphql-codegen --config codegen.yml",
    "prisma-gen": "npx prisma generate",
    "studio": "npx prisma studio"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@graphql-codegen/cli": "1.18.0",
    "@graphql-codegen/typescript": "1.17.11",
    "@graphql-codegen/typescript-operations": "1.17.8",
    "@graphql-codegen/typescript-react-apollo": "2.0.7",
    "@types/classnames": "^2.2.11",
    "@types/netmask": "^1.0.30",
    "@types/react-bootstrap-table-next": "^4.0.10",
    "@types/react-bootstrap-table2-paginator": "^2.1.1",
    "@types/react-copy-to-clipboard": "^5.0.0",
    "@types/reactstrap": "^8.5.1",
    "css-loader": "^3.4.2",
    "mini-css-extract-plugin": "^0.9.0",
    "node-sass": "^4.14.1",
    "prettier": "2.1.2",
    "sass-loader": "^8.0.2",
    "style-loader": "^0.23.1",
    "ts-node": "^10.1.0"
  },
  "jest": {
    "roots": [
      "<rootDir>/client"
    ],
    "collectCoverageFrom": [
      "client/**/*.{js,jsx,ts,tsx}",
      "!client/**/*.d.ts"
    ],
    "setupFiles": [
      "react-app-polyfill/jsdom"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/client/setupTests.js"
    ],
    "testMatch": [
      "<rootDir>/client/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/client/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jest-environment-jsdom-fourteen",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "modulePaths": [],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  }
}
